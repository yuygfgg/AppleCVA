set(_applecva_app "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/@APPLECVA_APP_NAME@.app")
set(_applecva_app_rel "@APPLECVA_APP_NAME@.app")

if(NOT EXISTS "${_applecva_app}")
    message(FATAL_ERROR "App bundle not found: ${_applecva_app}")
endif()

include("@CMAKE_CURRENT_BINARY_DIR@/.qt/QtDeploySupport.cmake")

file(REMOVE_RECURSE
    "${_applecva_app}/Contents/PlugIns"
    "${_applecva_app}/Contents/Resources/qml")
file(GLOB _applecva_stale_qt_frameworks
    "${_applecva_app}/Contents/Frameworks/Qt*.framework")
file(GLOB _applecva_stale_framework_dylibs
    "${_applecva_app}/Contents/Frameworks/*.dylib")
list(REMOVE_ITEM _applecva_stale_framework_dylibs
    "${_applecva_app}/Contents/Frameworks/libapplecva.dylib")
file(REMOVE_RECURSE ${_applecva_stale_qt_frameworks})
file(REMOVE ${_applecva_stale_framework_dylibs})

qt6_deploy_qml_imports(TARGET vts_source PLUGINS_FOUND _applecva_qml_plugins)

set(_applecva_qml_source_root
    "${__QT_DEPLOY_QT_INSTALL_PREFIX}/${__QT_DEPLOY_QT_INSTALL_DATA}/qml")
file(GLOB_RECURSE _applecva_qml_links
     LIST_DIRECTORIES false
     "${_applecva_app}/Contents/Resources/qml/*")
foreach(_applecva_qml_link IN LISTS _applecva_qml_links)
    if(IS_SYMLINK "${_applecva_qml_link}")
        file(READ_SYMLINK "${_applecva_qml_link}" _applecva_qml_link_target)
        if(_applecva_qml_link_target MATCHES "Cellar" OR
                IS_ABSOLUTE "${_applecva_qml_link_target}")
            file(RELATIVE_PATH _applecva_qml_link_rel
                 "${_applecva_app}/Contents/Resources/qml"
                 "${_applecva_qml_link}")
            set(_applecva_qml_link_source
                "${_applecva_qml_source_root}/${_applecva_qml_link_rel}")
            file(REAL_PATH "${_applecva_qml_link_source}"
                 _applecva_qml_link_source_real)
            if(NOT EXISTS "${_applecva_qml_link_source_real}")
                message(FATAL_ERROR
                        "Could not resolve QML resource symlink: ${_applecva_qml_link}")
            endif()
            get_filename_component(_applecva_qml_link_dest_dir
                                   "${_applecva_qml_link}" DIRECTORY)
            file(REMOVE "${_applecva_qml_link}")
            file(INSTALL
                "${_applecva_qml_link_source_real}"
                DESTINATION "${_applecva_qml_link_dest_dir}")
        endif()
    endif()
endforeach()

foreach(_applecva_qml_plugin IN LISTS _applecva_qml_plugins)
    set(_applecva_qml_plugin_dest
        "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/${_applecva_qml_plugin}")
    if(IS_SYMLINK "${_applecva_qml_plugin_dest}")
        get_filename_component(_applecva_qml_plugin_name
                               "${_applecva_qml_plugin_dest}" NAME)
        get_filename_component(_applecva_qml_plugin_dest_dir
                               "${_applecva_qml_plugin_dest}" DIRECTORY)
        file(GLOB_RECURSE _applecva_qml_plugin_candidates
             LIST_DIRECTORIES false
             "${_applecva_qml_source_root}/*/${_applecva_qml_plugin_name}")
        set(_applecva_qml_plugin_real "")
        foreach(_applecva_qml_plugin_candidate IN LISTS _applecva_qml_plugin_candidates)
            file(REAL_PATH "${_applecva_qml_plugin_candidate}"
                 _applecva_qml_plugin_candidate_real)
            if(EXISTS "${_applecva_qml_plugin_candidate_real}")
                set(_applecva_qml_plugin_real
                    "${_applecva_qml_plugin_candidate_real}")
                break()
            endif()
        endforeach()
        if(NOT _applecva_qml_plugin_real)
            message(FATAL_ERROR
                    "Could not resolve QML plugin symlink: ${_applecva_qml_plugin_dest}")
        endif()
        file(REMOVE "${_applecva_qml_plugin_dest}")
        file(INSTALL
            "${_applecva_qml_plugin_real}"
            DESTINATION "${_applecva_qml_plugin_dest_dir}"
            USE_SOURCE_PERMISSIONS)
    endif()
endforeach()

set(_applecva_platform_plugin_source
    "${__QT_DEPLOY_QT_INSTALL_PREFIX}/${__QT_DEPLOY_QT_INSTALL_PLUGINS}/platforms/libqcocoa.dylib")
if(NOT EXISTS "${_applecva_platform_plugin_source}")
    message(FATAL_ERROR
            "Qt Cocoa platform plugin not found: ${_applecva_platform_plugin_source}")
endif()

set(_applecva_platform_plugin_rel
    "${_applecva_app_rel}/Contents/PlugIns/platforms/libqcocoa.dylib")
file(INSTALL
    "${_applecva_platform_plugin_source}"
    DESTINATION "${_applecva_app}/Contents/PlugIns/platforms"
    USE_SOURCE_PERMISSIONS)

qt6_deploy_runtime_dependencies(
    EXECUTABLE "${_applecva_app_rel}"
    ADDITIONAL_MODULES
        ${_applecva_qml_plugins}
        "${_applecva_platform_plugin_rel}"
    NO_PLUGINS
    NO_TRANSLATIONS
    DEPLOY_TOOL_OPTIONS
        "-no-strip"
        "-no-codesign")

execute_process(
    COMMAND
        /usr/bin/codesign
        --force
        --deep
        --sign
        "@APPLECVA_CODESIGN_IDENTITY@"
        "${_applecva_app}"
    RESULT_VARIABLE _applecva_codesign_result)
if(NOT _applecva_codesign_result EQUAL 0)
    message(FATAL_ERROR "codesign failed with exit code ${_applecva_codesign_result}")
endif()
